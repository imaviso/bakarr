{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "erasableSyntaxOnly": false,
    "verbatimModuleSyntax": false,
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "paths": {
      "@bakarr/shared": ["../../packages/shared/src/index.ts"],
      "@/*": ["./src/*"],
      "~/*": ["./src/*"]
    },
    "plugins": [
      {
        "name": "@effect/language-service"
      }
    ]
  },
  "include": ["src", "../../packages/shared/src/index.ts"]
}
