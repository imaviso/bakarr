{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // General
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    // Modules
    "isolatedModules": true,

    "types": ["vite/client"],
    "paths": {
      "@bakarr/shared": ["../../packages/shared/src/index.ts"],
      "~/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
