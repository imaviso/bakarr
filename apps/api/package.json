{
  "name": "@bakarr/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch main.ts",
    "start": "node build/main.js",
    "build": "tsx ./tools/generate-embedded-artifacts.ts && rolldown -c",
    "check": "tsc --noEmit",
    "generate:embedded-artifacts": "tsx ./tools/generate-embedded-artifacts.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@bakarr/shared": "workspace:*",
    "@effect/experimental": "^0.61.0",
    "@effect/opentelemetry": "^0.64.0",
    "@effect/platform": "^0.97.0",
    "@effect/platform-node": "^0.108.0",
    "@effect/sql": "^0.52.0",
    "@effect/sql-drizzle": "^0.51.0",
    "@effect/sql-sqlite-node": "^0.53.0",
    "@opentelemetry/api": "^1.9.1",
    "better-sqlite3": "^13.0.1",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.22.0",
    "fast-xml-parser": "^5.10.1",
    "ipaddr.js": "^2.4.0"
  },
  "devDependencies": {
    "@effect/vitest": "^0.30.0",
    "@types/node": "26.1.1",
    "drizzle-kit": "^0.31.10",
    "rolldown": "^1.2.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
