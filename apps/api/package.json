{
  "name": "@bakarr/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch main.ts",
    "start": "bun run main.ts",
    "build": "bun run generate:embedded-artifacts && bun build --production --compile --bytecode --minify --sourcemap --format=esm --outfile=./build/bakarr ./main.ts",
    "check": "tsc --noEmit",
    "generate:embedded-artifacts": "bun run ./tools/generate-embedded-artifacts.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio"
  },
  "dependencies": {
    "@bakarr/shared": "workspace:*",
    "@effect/experimental": "^0.60.0",
    "@effect/platform": "^0.96.0",
    "@effect/platform-bun": "^0.89.0",
    "@effect/sql": "^0.51.0",
    "@effect/sql-drizzle": "^0.50.0",
    "@effect/sql-sqlite-bun": "^0.52.0",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.1",
    "fast-xml-parser": "^5.7.1",
    "ipaddr.js": "^2.3.0"
  },
  "devDependencies": {
    "@effect/sql-sqlite-node": "^0.52.0"
  }
}
