{
  "name": "@bakarr/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch main.ts",
    "start": "node build/main.js",
    "build": "tsx ./tools/generate-embedded-artifacts.ts && rolldown -c",
    "check": "tsc --noEmit",
    "generate:embedded-artifacts": "tsx ./tools/generate-embedded-artifacts.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@bakarr/shared": "workspace:*",
    "@effect/experimental": "^0.60.0",
    "@effect/opentelemetry": "^0.63.0",
    "@effect/platform": "^0.96.1",
    "@effect/platform-node": "^0.106.0",
    "@effect/sql": "^0.51.1",
    "@effect/sql-drizzle": "^0.50.0",
    "@effect/sql-sqlite-node": "^0.52.0",
    "@opentelemetry/api": "^1.9.1",
    "better-sqlite3": "^12.5.0",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.2",
    "fast-xml-parser": "^5.8.0",
    "ipaddr.js": "^2.4.0"
  },
  "devDependencies": {
    "@effect/vitest": "^0.29.0",
    "@types/node": "25.5.0",
    "drizzle-kit": "^0.31.10",
    "rolldown": "^1.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
