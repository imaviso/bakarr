{
  "tasks": {
    "build": "deno task check",
    "check": "deno check main.ts main_test.ts",
    "dev": "deno run --watch --allow-env --allow-ffi --allow-net --allow-read --allow-sys --allow-write main.ts",
    "start": "deno run --allow-env --allow-ffi --allow-net --allow-read --allow-sys --allow-write main.ts",
    "test": "deno test --allow-env --allow-ffi --allow-read --allow-sys --allow-write",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/dotenv/load": "jsr:@std/dotenv@^0.225.5/load",
    "@libsql/client": "npm:@libsql/client@^0.17.0",
    "drizzle-orm": "npm:drizzle-orm@^0.45.1",
    "effect": "npm:effect@^3.19.19",
    "hono": "npm:hono@^4.12.7"
  }
}
