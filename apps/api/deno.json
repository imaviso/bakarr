{
  "tasks": {
    "build": "deno task check",
    "check": "deno check main.ts main_test.ts",
    "dev": "deno run --watch --allow-env --allow-ffi --allow-net --allow-read --allow-run=ffprobe --allow-sys --allow-write main.ts",
    "start": "deno run --allow-env --allow-ffi --allow-net --allow-read --allow-run=ffprobe --allow-sys --allow-write main.ts",
    "test": "deno test --allow-env --allow-ffi --allow-read --allow-run=ffprobe --allow-sys --allow-write",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "imports": {
    "@effect/platform": "npm:@effect/platform@^0.95.0",
    "@effect/language-service": "npm:@effect/language-service@^0.79.0",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/dotenv/load": "jsr:@std/dotenv@^0.225.6/load",
    "@libsql/client": "npm:@libsql/client@^0.17.0",
    "drizzle-orm": "npm:drizzle-orm@^0.45.1",
    "effect": "npm:effect@^3.20.0",
    "hono": "npm:hono@^4.12.8",
    "fast-xml-parser": "npm:fast-xml-parser@^5.5.6",
    "ipaddr.js": "npm:ipaddr.js@^2.3.0",
    "drizzle-kit": "npm:drizzle-kit@^0.31.10",
    "typescript": "npm:typescript@^5.9.3"
  }
}
