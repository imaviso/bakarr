{
  "name": "bakarr",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run ./tools/dev.ts",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:web": "bun run --cwd apps/web dev",
    "build": "bun run --cwd apps/api build && bun run --cwd apps/web build",
    "test": "bun run --cwd apps/api test",
    "effect": "bun run --cwd apps/api check",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "tsgolint": "oxlint --type-aware --type-check"
  },
  "devDependencies": {
    "@effect/language-service": "^0.79.0",
    "@effect/vitest": "^0.29.0",
    "@types/bun": "latest",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.3",
    "postcss": "^8.5.8",
    "solid-devtools": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-solid": "^2.11.11",
    "vitest": "^4.1.0"
  }
}
