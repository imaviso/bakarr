{
  "name": "bakarr",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run ./tools/dev.ts",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:web": "bun run --cwd apps/web dev",
    "build": "bun run build:api && bun run build:web",
    "build:api": "bun run --cwd apps/api build",
    "build:web": "bun run --cwd apps/web build",
    "test": "bun run test:api && bun run test:web",
    "test:api": "bun run --cwd apps/api test",
    "test:web": "bun run --cwd apps/web test",
    "check": "bun run check:api && bun run check:web",
    "check:api": "bun run --cwd apps/api check",
    "check:web": "bun run --cwd apps/web check",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "bun run lint:api && bun run lint:web",
    "lint:api": "bun run --cwd apps/api lint",
    "lint:web": "bun run --cwd apps/web lint",
    "lint:fix": "oxlint --fix"
  },
  "devDependencies": {
    "@effect/language-service": "^0.79.0",
    "@effect/vitest": "^0.29.0",
    "@types/bun": "latest",
    "autoprefixer": "^10.4.27",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.18.0",
    "postcss": "^8.5.8",
    "solid-devtools": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.2",
    "vite": "^8.0.1",
    "vite-plugin-solid": "^2.11.11",
    "vitest": "^4.1.0"
  }
}
